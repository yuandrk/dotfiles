# Ghostty configuration
# Docs: https://ghostty.org/docs/config
# Managed by dotfiles — symlinked to ~/.config/ghostty/config by install.sh.
# Replaces the manually-configured iTerm2 setup; colors below are ported
# directly from the iTerm2 "Default" profile.

# --- Font ---
# JetBrainsMono Nerd Font is installed via the Brewfile and provides the
# powerline glyphs/icons used by the Starship prompt.
font-family = "JetBrainsMono Nerd Font"
font-size = 13

# --- Colors (ported from iTerm2 "Default" profile, light theme) ---
background = #fafafa
foreground = #101010
cursor-color = #000000
cursor-text = #ffffff
selection-background = #b3d7ff
selection-foreground = #000000

# 16-color ANSI palette
palette = 0=#14191e
palette = 1=#b43c2a
palette = 2=#00c200
palette = 3=#c7c400
palette = 4=#2744c7
palette = 5=#c040be
palette = 6=#00c5c7
palette = 7=#c7c7c7
palette = 8=#686868
palette = 9=#dd7975
palette = 10=#58e790
palette = 11=#ece100
palette = 12=#a7abf2
palette = 13=#e17ee1
palette = 14=#60fdff
palette = 15=#ffffff

# --- Cursor ---
cursor-style = block
mouse-hide-while-typing = true

# --- Window ---
window-padding-x = 8
window-padding-y = 8
confirm-close-surface = false

# --- Behavior ---
copy-on-select = clipboard
shell-integration = zsh

# --- tmux integration ---
# Launch into a shared tmux session named "main" (attach if it already exists,
# create it otherwise). Falls back to a normal login shell if tmux is missing
# so Ghostty always opens. Every Ghostty window attaches to this same session,
# so reopening Ghostty drops you straight back where you left off. Across a
# reboot, tmux-continuum (see tmux.conf) restores the previous session's
# windows, panes, layouts and nvim sessions when the server first starts.
command = zsh -l -c "tmux new-session -A -s main || exec zsh -l"

# Native macOS shortcuts that drive tmux (prefix is Ctrl-a = \x01):
#   Cmd+T        new tmux window           (prefix c)
#   Cmd+W        close current pane        (prefix x — tmux asks to confirm)
#   Cmd+D        split right               (prefix | )
#   Cmd+Shift+D  split down                (prefix - )
#   Cmd+1..9     jump to tmux window N      (prefix N)
# Cmd+C / Cmd+V keep Ghostty's default copy/paste. To close the Ghostty window
# itself (not a tmux pane) use Cmd+Q or the window's close button.
keybind = cmd+t=text:\x01c
keybind = cmd+w=text:\x01x
keybind = cmd+d=text:\x01|
keybind = cmd+shift+d=text:\x01-
keybind = cmd+one=text:\x011
keybind = cmd+two=text:\x012
keybind = cmd+three=text:\x013
keybind = cmd+four=text:\x014
keybind = cmd+five=text:\x015
keybind = cmd+six=text:\x016
keybind = cmd+seven=text:\x017
keybind = cmd+eight=text:\x018
keybind = cmd+nine=text:\x019
