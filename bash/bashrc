# ============================================================================
# KUBERNETES (K8S) CONFIGURATION
# ============================================================================

# --- Kubectl Completion ---
if command -v kubectl &> /dev/null; then
    source <(kubectl completion bash)

    # Enable kubectl alias completion
    complete -o default -F __start_kubectl k
fi

# --- Kubernetes Aliases ---
alias k='kubectl'
alias kgp='kubectl get pods'
alias kgs='kubectl get svc'
alias kgd='kubectl get deployments'
alias kgn='kubectl get nodes'
alias kga='kubectl get all'
alias kgpa='kubectl get pods --all-namespaces'
alias kdp='kubectl describe pod'
alias kds='kubectl describe svc'
alias kdd='kubectl describe deployment'
alias kdn='kubectl describe node'
alias kdel='kubectl delete'
alias kl='kubectl logs'
alias klf='kubectl logs -f'
alias kex='kubectl exec -it'
alias kap='kubectl apply -f'
alias kdelp='kubectl delete pod'

# Context and namespace shortcuts
alias kctx='kubectx'
alias kns='kubens'
alias kgc='kubectl config get-contexts'
alias kcc='kubectl config current-context'

# --- Kubernetes Functions ---

# Quick pod shell access
kshell() {
    if [ -z "$1" ]; then
        echo "Usage: kshell <pod-name> [container-name]"
        return 1
    fi
    if [ -z "$2" ]; then
        kubectl exec -it "$1" -- /bin/sh
    else
        kubectl exec -it "$1" -c "$2" -- /bin/sh
    fi
}

# Quick bash access (for pods with bash)
kbash() {
    if [ -z "$1" ]; then
        echo "Usage: kbash <pod-name> [container-name]"
        return 1
    fi
    if [ -z "$2" ]; then
        kubectl exec -it "$1" -- /bin/bash
    else
        kubectl exec -it "$1" -c "$2" -- /bin/bash
    fi
}

# Get pod by partial name
kgpw() {
    kubectl get pods | grep -i "$1"
}

# Watch pods
kwp() {
    watch -n 2 kubectl get pods
}

# Get events sorted by time
kevents() {
    kubectl get events --sort-by='.lastTimestamp'
}

# Port forward with common pattern
kpf() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: kpf <pod-name> <port>"
        echo "Example: kpf my-pod 8080"
        return 1
    fi
    kubectl port-forward "$1" "$2:$2"
}

# Get resource usage
ktop() {
    if [ "$1" = "pod" ] || [ "$1" = "pods" ]; then
        kubectl top pods
    elif [ "$1" = "node" ] || [ "$1" = "nodes" ]; then
        kubectl top nodes
    else
        echo "Top pods:"
        kubectl top pods 2>/dev/null
        echo ""
        echo "Top nodes:"
        kubectl top nodes 2>/dev/null
    fi
}

# Restart deployment
krestart() {
    if [ -z "$1" ]; then
        echo "Usage: krestart <deployment-name>"
        return 1
    fi
    kubectl rollout restart deployment "$1"
}

