# ============================================================================
# KIND (Kubernetes IN Docker) CONFIGURATION
# ============================================================================

# --- kind Aliases ---
alias kind-create='kind create cluster'
alias kind-delete='kind delete cluster'
alias kind-list='kind get clusters'
alias kind-load='kind load docker-image'

# --- kind Helper Functions ---

# Create a kind cluster with a custom name
kind-new() {
    local cluster_name="${1:-kind}"
    echo "Creating kind cluster: $cluster_name"
    kind create cluster --name "$cluster_name"
}

# Create a multi-node cluster
kind-multi() {
    local cluster_name="${1:-kind-multi}"
    local config_file="/tmp/kind-multi-node.yaml"

    cat > "$config_file" << 'EOF'
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
nodes:
- role: control-plane
- role: worker
- role: worker
EOF

    echo "Creating multi-node cluster: $cluster_name"
    kind create cluster --name "$cluster_name" --config "$config_file"
    rm "$config_file"
}

# Create cluster with port mapping (useful for testing services)
kind-with-ports() {
    local cluster_name="${1:-kind-ports}"
    local config_file="/tmp/kind-ports.yaml"

    cat > "$config_file" << 'EOF'
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
nodes:
- role: control-plane
  extraPortMappings:
  - containerPort: 80
    hostPort: 80
    protocol: TCP
  - containerPort: 443
    hostPort: 443
    protocol: TCP
  - containerPort: 30000
    hostPort: 30000
    protocol: TCP
EOF

    echo "Creating cluster with port mappings: $cluster_name"
    kind create cluster --name "$cluster_name" --config "$config_file"
    rm "$config_file"
}

# Delete all kind clusters
kind-clean() {
    echo "Deleting all kind clusters..."
    kind get clusters | xargs -I {} kind delete cluster --name {}
}

# Quick switch to kind cluster context
kind-use() {
    local cluster_name="${1:-kind}"
    kubectl cluster-info --context "kind-${cluster_name}"
    kubectl config use-context "kind-${cluster_name}"
}

# Load local Docker image into kind cluster
kind-img() {
    if [ -z "$1" ]; then
        echo "Usage: kind-img <image-name> [cluster-name]"
        echo "Example: kind-img my-app:latest"
        return 1
    fi
    local image="$1"
    local cluster="${2:-kind}"
    echo "Loading image $image into cluster $cluster"
    kind load docker-image "$image" --name "$cluster"
}

# Get nodes of a kind cluster
kind-nodes() {
    local cluster="${1:-kind}"
    echo "Nodes for cluster: $cluster"
    kubectl get nodes --context "kind-${cluster}"
}

# --- Editor ---
export EDITOR=vim
export VISUAL=vim

# Uncomment the following line if you don't like systemctl's auto-paging feature:
